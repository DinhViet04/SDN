<%- include('../partials/header') %>

    <div class="page-header">
        <div>
            <h1>
                <%= booking ? '✏️ Edit Booking' : '➕ New Booking' %>
            </h1>
            <p>
                <%= booking ? 'Update rental details below' : 'Fill in booking information below' %>
            </p>
        </div>
        <a href="/bookings" class="btn btn-ghost">← Back to Bookings</a>
    </div>

    <div class="card form-card" style="padding: 2rem;">
        <% if (typeof error !=='undefined' && error) { %>
            <div class="alert alert-danger">⚠️ <%= error %>
            </div>
            <% } %>

                <form method="POST" action="<%= booking ? '/bookings/' + booking._id : '/bookings' %>"
                    class="form-grid">
                    <% if (booking) { %>
                        <input type="hidden" name="_method" value="PUT" />
                        <% } %>

                            <div class="form-group">
                                <label for="customerName">Customer Name</label>
                                <input type="text" id="customerName" name="customerName"
                                    value="<%= booking ? booking.customerName : '' %>" placeholder="e.g. Nguyen Van A"
                                    required />
                            </div>

                            <div class="form-group">
                                <label for="carNumber">Car Number</label>
                                <select id="carNumber" name="carNumber" required>
                                    <option value="">-- Select a car --</option>
                                    <% cars.forEach(car=> { %>
                                        <option value="<%= car.carNumber %>" <%=(booking &&
                                            booking.carNumber===car.carNumber) ? 'selected' : '' %>
                                            >
                                            <%= car.carNumber %> — <%= car.capacity %> seats — ₫<%=
                                                        car.pricePerDay.toLocaleString('vi-VN') %>/day
                                                        (<%= car.status %>)
                                        </option>
                                        <% }) %>
                                </select>
                                <span class="hint">Total amount will be calculated automatically</span>
                            </div>

                            <div class="form-group">
                                <label for="startDate">Start Date</label>
                                <input type="date" id="startDate" name="startDate"
                                    value="<%= booking ? new Date(booking.startDate).toISOString().split('T')[0] : '' %>"
                                    required />
                            </div>

                            <div class="form-group">
                                <label for="endDate">End Date</label>
                                <input type="date" id="endDate" name="endDate"
                                    value="<%= booking ? new Date(booking.endDate).toISOString().split('T')[0] : '' %>"
                                    required />
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary">
                                    <%= booking ? '💾 Save Changes' : '📋 Create Booking' %>
                                </button>
                                <a href="/bookings" class="btn btn-ghost">Cancel</a>
                            </div>
                </form>
    </div>

    <%- include('../partials/footer') %>