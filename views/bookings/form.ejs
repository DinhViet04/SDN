<%- include('../partials/header', { title: booking ? 'Sửa lịch đặt' : 'Đặt xe' }) %>
<%- include('../partials/requireAuth') %>

<style>
    .form-page {
        max-width: 720px;
        margin: 0 auto;
    }

    .modern-card {
        background: rgba(30, 41, 59, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        padding: 2.5rem;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.25);
    }

    .field-label {
        display: block;
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }

    .modern-input,
    .modern-select {
        width: 100%;
        padding: 0.85rem 1rem;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(0, 0, 0, 0.2);
        color: var(--text);
        font-size: 0.95rem;
        font-family: inherit;
        outline: none;
        transition: all 0.2s;
        -webkit-appearance: none;
        appearance: none;
    }

    .modern-input:focus,
    .modern-select:focus {
        border-color: var(--accent);
        background: rgba(59, 130, 246, 0.05);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
    }

    .modern-select option {
        background: #1e293b;
    }

    .field-hint {
        font-size: 0.78rem;
        color: var(--muted);
        margin-top: 0.4rem;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
    }

    @media (max-width: 600px) {
        .form-row { grid-template-columns: 1fr; }
        .modern-card { padding: 1.5rem; }
    }

    .form-field {
        display: flex;
        flex-direction: column;
        margin-bottom: 1.25rem;
    }

    .submit-btn {
        width: 100%;
        padding: 0.95rem;
        border-radius: 14px;
        border: none;
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
        color: white;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.4);
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 30px -5px rgba(59, 130, 246, 0.55);
    }

    .price-preview {
        background: rgba(16, 185, 129, 0.08);
        border: 1px solid rgba(16, 185, 129, 0.2);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.25rem;
        display: none;
    }

    .price-preview .preview-label {
        font-size: 0.8rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 600;
        margin-bottom: 0.4rem;
    }

    .price-preview .preview-value {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--success);
    }

    .car-option-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.2rem 0.6rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        background: rgba(16, 185, 129, 0.15);
        color: var(--success);
    }
</style>

<div class="form-page">
    <div class="page-header" style="margin-bottom: 2rem;">
        <div>
            <h1 style="font-size: 2rem; font-weight: 800;"><%= booking ? '✏️ Sửa lịch đặt xe' : '🗓️ Đặt xe mới' %></h1>
            <p style="color: var(--muted); margin-top: 0.3rem;"><%= booking ? 'Cập nhật thông tin đặt xe' : 'Điền thông tin để đặt xe theo lịch của bạn' %></p>
        </div>
        <a href="/bookings" class="btn btn-ghost" style="border-radius: 12px; padding: 0.6rem 1.25rem;">← Quay lại</a>
    </div>

    <div class="modern-card">
        <% if (typeof error !== 'undefined' && error) { %>
            <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); border-radius: 12px; padding: 1rem 1.25rem; margin-bottom: 1.5rem; color: #fca5a5; font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem;">
                ⚠️ <%= error %>
            </div>
        <% } %>

        <form method="POST" action="<%= booking ? '/bookings/' + booking._id : '/bookings' %>" class="form-grid" id="bookingForm">
            <% if (booking) { %>
                <input type="hidden" name="_method" value="PUT" />
            <% } %>

            <div class="form-field">
                <label class="field-label" for="customerName">Tên khách hàng</label>
                <input type="text" class="modern-input" id="customerName" name="customerName"
                    value="<%= booking ? booking.customerName : '' %>"
                    placeholder="VD: Nguyễn Văn A" required />
            </div>

            <div class="form-field">
                <label class="field-label" for="carNumber">Chọn xe</label>
                <select class="modern-select" id="carNumber" name="carNumber" required onchange="updatePricePreview()">
                    <option value="">-- Chọn xe --</option>
                    <% cars.forEach(car=> { %>
                        <option value="<%= car.carNumber %>"
                            data-price="<%= car.pricePerDay %>"
                            data-capacity="<%= car.capacity %>"
                            data-status="<%= car.status %>"
                            <%= (booking && booking.carNumber === car.carNumber) ? 'selected' : '' %>
                            <%= car.status !== 'available' && !(booking && booking.carNumber === car.carNumber) ? 'disabled' : '' %>
                        >
                            <%= car.carNumber %> — <%= car.capacity %> chỗ — ₫<%= car.pricePerDay.toLocaleString('vi-VN') %>/ngày
                            <%= car.status !== 'available' ? '(Không khả dụng)' : '' %>
                        </option>
                    <% }) %>
                </select>
                <span class="field-hint">💡 Chỉ hiển thị xe đang sẵn sàng. Giá sẽ được tính dựa theo số ngày thuê.</span>
            </div>

            <div class="form-row">
                <div class="form-field">
                    <label class="field-label" for="startDate">Ngày bắt đầu</label>
                    <input type="date" class="modern-input" id="startDate" name="startDate"
                        value="<%= booking ? new Date(booking.startDate).toISOString().split('T')[0] : '' %>"
                        min="<%= new Date().toISOString().split('T')[0] %>"
                        required onchange="updatePricePreview()" />
                </div>
                <div class="form-field">
                    <label class="field-label" for="endDate">Ngày kết thúc</label>
                    <input type="date" class="modern-input" id="endDate" name="endDate"
                        value="<%= booking ? new Date(booking.endDate).toISOString().split('T')[0] : '' %>"
                        required onchange="updatePricePreview()" />
                </div>
            </div>

            <!-- Live Price Preview -->
            <div class="price-preview" id="pricePreview">
                <div class="preview-label">💰 Dự tính thanh toán</div>
                <div class="preview-value" id="previewAmount">—</div>
                <div id="previewDays" style="font-size: 0.85rem; color: var(--muted); margin-top: 0.25rem;"></div>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 0.75rem;">
                <button type="submit" class="submit-btn">
                    <%= booking ? '💾 Lưu thay đổi' : '🗓️ Xác nhận đặt xe' %>
                </button>
                <a href="/bookings" class="btn btn-ghost" style="border-radius: 12px; padding: 0 1.5rem; display: flex; align-items: center;">Hủy</a>
            </div>
        </form>
    </div>
</div>

<script>
    function updatePricePreview() {
        const carSelect = document.getElementById('carNumber');
        const startInput = document.getElementById('startDate');
        const endInput = document.getElementById('endDate');
        const preview = document.getElementById('pricePreview');
        const amountEl = document.getElementById('previewAmount');
        const daysEl = document.getElementById('previewDays');

        const selectedOption = carSelect.options[carSelect.selectedIndex];
        const pricePerDay = parseFloat(selectedOption?.getAttribute('data-price') || 0);
        const start = new Date(startInput.value);
        const end = new Date(endInput.value);

        // Update endDate min
        if (startInput.value) {
            const nextDay = new Date(start);
            nextDay.setDate(nextDay.getDate() + 1);
            endInput.min = nextDay.toISOString().split('T')[0];
        }

        if (!pricePerDay || !startInput.value || !endInput.value || end <= start) {
            preview.style.display = 'none';
            return;
        }

        const days = Math.ceil((end - start) / (1000 * 60 * 60 * 24));
        const total = days * pricePerDay;

        amountEl.textContent = '₫' + total.toLocaleString('vi-VN');
        daysEl.textContent = days + ' ngày × ₫' + pricePerDay.toLocaleString('vi-VN') + '/ngày';
        preview.style.display = 'block';
    }

    // init on page load (for edit mode)
    document.addEventListener('DOMContentLoaded', updatePricePreview);
</script>

<%- include('../partials/footer') %>