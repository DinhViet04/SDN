<%- include('../partials/header', { title: car ? 'Sửa xe' : 'Thêm xe mới' }) %>
<%- include('../partials/requireAuth') %>

<script>
    /* Admin-only guard */
    (function () {
        const u = JSON.parse(localStorage.getItem('user') || '{}');
        if (u.role !== 'admin') window.location.replace('/cars');
    })();
</script>

<style>
    .form-page {
        max-width: 680px;
        margin: 0 auto;
    }

    .modern-card {
        background: rgba(30, 41, 59, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        padding: 2.5rem;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.25);
    }

    .field-label {
        display: block;
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }

    .modern-input,
    .modern-select {
        width: 100%;
        padding: 0.85rem 1rem;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(0, 0, 0, 0.2);
        color: var(--text);
        font-size: 0.95rem;
        font-family: inherit;
        outline: none;
        transition: all 0.2s;
        -webkit-appearance: none;
        appearance: none;
    }

    .modern-input:focus,
    .modern-select:focus {
        border-color: var(--accent);
        background: rgba(59, 130, 246, 0.05);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
    }

    .modern-select option {
        background: #1e293b;
    }

    .field-hint {
        font-size: 0.78rem;
        color: var(--muted);
        margin-top: 0.4rem;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
    }

    @media (max-width: 600px) {
        .form-row { grid-template-columns: 1fr; }
        .modern-card { padding: 1.5rem; }
    }

    .form-field {
        display: flex;
        flex-direction: column;
        margin-bottom: 1.25rem;
    }

    .submit-btn {
        width: 100%;
        padding: 0.95rem;
        border-radius: 14px;
        border: none;
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
        color: white;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.4);
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 30px -5px rgba(59, 130, 246, 0.55);
    }

    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.35rem 0.85rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 700;
    }
</style>

<div class="form-page">
    <div class="page-header" style="margin-bottom: 2rem;">
        <div>
            <h1 style="font-size: 2rem; font-weight: 800;"><%= car ? '✏️ Sửa thông tin xe' : '🚗 Thêm xe mới' %></h1>
            <p style="color: var(--muted); margin-top: 0.3rem;"><%= car ? 'Cập nhật thông tin xe bên dưới' : 'Điền đầy đủ thông tin xe để thêm vào hệ thống' %></p>
        </div>
        <a href="/cars" class="btn btn-ghost" style="border-radius: 12px; padding: 0.6rem 1.25rem;">← Quay lại</a>
    </div>

    <div class="modern-card">
        <% if (typeof error !== 'undefined' && error) { %>
            <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); border-radius: 12px; padding: 1rem 1.25rem; margin-bottom: 1.5rem; color: #fca5a5; font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem;">
                ⚠️ <%= error %>
            </div>
        <% } %>

        <form method="POST" action="<%= car ? '/cars/' + car._id : '/cars' %>" class="form-grid">
            <% if (car) { %>
                <input type="hidden" name="_method" value="PUT" />
            <% } %>

            <div class="form-row">
                <div class="form-field">
                    <label class="field-label" for="carNumber">Biển số xe</label>
                    <input type="text" class="modern-input" id="carNumber" name="carNumber"
                        value="<%= car ? car.carNumber : '' %>"
                        placeholder="VD: 51A-12345" required />
                </div>
                <div class="form-field">
                    <label class="field-label" for="capacity">Số chỗ ngồi</label>
                    <input type="number" class="modern-input" id="capacity" name="capacity"
                        value="<%= car ? car.capacity : '' %>"
                        placeholder="VD: 7" min="1" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-field">
                    <label class="field-label" for="pricePerDay">Giá thuê / ngày (₫)</label>
                    <input type="number" class="modern-input" id="pricePerDay" name="pricePerDay"
                        value="<%= car ? car.pricePerDay : '' %>"
                        placeholder="VD: 500000" min="0" required />
                </div>
                <div class="form-field">
                    <label class="field-label" for="status">Trạng thái</label>
                    <select class="modern-select" id="status" name="status">
                        <option value="available" <%= (!car || car.status === 'available') ? 'selected' : '' %>>✅ Sẵn sàng (Available)</option>
                        <option value="rented" <%= (car && car.status === 'rented') ? 'selected' : '' %>>🔑 Đang thuê (Rented)</option>
                        <option value="maintenance" <%= (car && car.status === 'maintenance') ? 'selected' : '' %>>🔧 Bảo trì (Maintenance)</option>
                    </select>
                </div>
            </div>

            <div class="form-field">
                <label class="field-label" for="features">Tính năng / tiện ích</label>
                <input type="text" class="modern-input" id="features" name="features"
                    value="<%= car ? car.features.join(', ') : '' %>"
                    placeholder="VD: automatic, air-conditioner, GPS, camera, bluetooth" />
                <span class="field-hint">💡 Nhập các tính năng cách nhau bởi dấu phẩy</span>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 0.75rem;">
                <button type="submit" class="submit-btn">
                    <%= car ? '💾 Lưu thay đổi' : '🚗 Thêm xe vào hệ thống' %>
                </button>
                <a href="/cars" class="btn btn-ghost" style="border-radius: 12px; padding: 0 1.5rem; display: flex; align-items: center;">Hủy</a>
            </div>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>