<%- include('../partials/header', { title: 'Quản lý Users' }) %>
    <%- include('../partials/requireAuth') %>

        <script>
            // Admin-only guard
            (function () {
                const u = JSON.parse(localStorage.getItem('user') || '{}');
                if (u.role !== 'admin') window.location.replace('/');
            })();
        </script>

        <div class="page-header">
            <div>
                <h1>⚙️ Quản lý Users</h1>
                <p>Xem danh sách và phân quyền tài khoản</p>
            </div>
            <span id="currentAdmin" class="badge"
                style="background:rgba(108,99,255,.15);color:var(--accent2);padding:.4rem 1rem;border-radius:8px;font-size:.85rem"></span>
        </div>

        <!-- Stats -->
        <div class="stats" id="statsRow" style="display:none">
            <div class="stat-card accent">
                <div class="label">Tổng Users</div>
                <div class="value" id="statTotal">—</div>
            </div>
            <div class="stat-card">
                <div class="label">Admins</div>
                <div class="value" id="statAdmins" style="color:var(--accent2)">—</div>
            </div>
            <div class="stat-card">
                <div class="label">Users</div>
                <div class="value" id="statUsers" style="color:var(--success)">—</div>
            </div>
        </div>

        <!-- Alert box -->
        <div id="alertBox" class="alert" style="display:none"></div>

        <!-- Loading -->
        <div id="loadingState" class="empty-state">
            <div class="icon">⏳</div>
            <p>Đang tải danh sách...</p>
        </div>

        <!-- Table -->
        <div class="card" id="tableCard" style="display:none">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Ngày tạo</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody id="usersBody"></tbody>
            </table>
        </div>

        <script>
            (async function () {
                const token = localStorage.getItem('token');
                const me = JSON.parse(localStorage.getItem('user') || '{}');
                document.getElementById('currentAdmin').textContent = '🛡️ ' + (me.username || 'Admin');

                function showAlert(msg, type = 'danger') {
                    const box = document.getElementById('alertBox');
                    box.textContent = msg;
                    box.className = 'alert alert-' + type;
                    box.style.display = '';
                    setTimeout(() => box.style.display = 'none', 4000);
                }

                async function loadUsers() {
                    try {
                        const res = await fetch('/api/auth/users', {
                            headers: { 'Authorization': 'Bearer ' + token }
                        });
                        if (res.status === 401) { localStorage.clear(); return window.location.replace('/auth/login'); }
                        if (res.status === 403) return window.location.replace('/');

                        const users = await res.json();

                        document.getElementById('loadingState').style.display = 'none';
                        document.getElementById('tableCard').style.display = '';
                        document.getElementById('statsRow').style.display = '';

                        const admins = users.filter(u => u.role === 'admin').length;
                        document.getElementById('statTotal').textContent = users.length;
                        document.getElementById('statAdmins').textContent = admins;
                        document.getElementById('statUsers').textContent = users.length - admins;

                        const tbody = document.getElementById('usersBody');
                        tbody.innerHTML = '';

                        users.forEach((u, i) => {
                            const isSelf = u.id === me.id;
                            const isAdmin = u.role === 'admin';

                            const roleBadge = isAdmin
                                ? '<span class="badge" style="background:rgba(108,99,255,.15);color:var(--accent2)">🛡️ Admin</span>'
                                : '<span class="badge" style="background:rgba(16,185,129,.1);color:var(--success)">👤 User</span>';

                            const actionBtn = isSelf
                                ? '<span style="color:var(--muted);font-size:.8rem">Tài khoản của bạn</span>'
                                : `<button onclick="toggleRole('${u.id}', '${u.role}')"
                            class="btn btn-sm ${isAdmin ? 'btn-warning' : 'btn-ghost'}">
                            ${isAdmin ? '⬇️ Đặt thành User' : '⬆️ Đặt thành Admin'}
                        </button>`;

                            tbody.insertAdjacentHTML('beforeend', `
                    <tr id="row-${u.id}">
                        <td style="color:var(--muted)">${i + 1}</td>
                        <td><strong>${u.username}</strong> ${isSelf ? '<span style="color:var(--accent2);font-size:.75rem">(bạn)</span>' : ''}</td>
                        <td style="color:var(--muted)">${u.email}</td>
                        <td>${roleBadge}</td>
                        <td style="color:var(--muted);font-size:.85rem">${new Date(u.createdAt).toLocaleDateString('vi-VN')}</td>
                        <td>${actionBtn}</td>
                    </tr>
                `);
                        });
                    } catch (err) {
                        document.getElementById('loadingState').style.display = '';
                        showAlert('Lỗi tải dữ liệu: ' + err.message);
                    }
                }

                window.toggleRole = async function (userId, currentRole) {
                    const newRole = currentRole === 'admin' ? 'user' : 'admin';
                    const confirm = window.confirm(`Đổi role sang "${newRole}"?`);
                    if (!confirm) return;

                    try {
                        const res = await fetch(`/api/auth/users/${userId}/role`, {
                            method: 'PUT',
                            headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
                            body: JSON.stringify({ role: newRole }),
                        });
                        const data = await res.json();
                        if (!res.ok) return showAlert(data.error || 'Thất bại');
                        showAlert(`✅ Đã đổi thành công sang ${newRole}`, 'success');
                        loadUsers(); // Reload table
                    } catch (err) {
                        showAlert('Lỗi: ' + err.message);
                    }
                };

                loadUsers();
            })();
        </script>

        <%- include('../partials/footer') %>